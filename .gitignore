ChatExport_Auto/
ChatExport_*/

# Локальная векторная база данных ChromaDB
chroma_db/

# Кэш-файлы (транскрибация, эмбеддинги)
*.pkl
*.json_cache

# Любые файлы экспорта Telegram
result.json

# --- Окружение и Зависимости ---
